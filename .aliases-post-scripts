# This is here because it relies on port_checker_local so has to be sourced after it
function kill_ports {
  if [ $# -eq 0 ]; then
    echo "No ports specified"
    return 0;
  fi

  for port in ${(f)1}; do
    # check if port in use
    for pid in ${(f)"$(on_port pid $port)"}; do
      if [[ "$pid" ]]; then
        echo "Killing process $YLW$pid$NONE on port $CYN$port$NONE"
        kill -9 $pid || echo "$RED""ERROR stopping port $YLW$port$NONE"
      else
        echo "Port $CYN$port$NONE is not in use"
      fi
    done
  done
}

function git-pull-latest-safely {
  if [ $# -eq 0 ]; then
    branch_name=$(git_current_branch)
  else
    branch_name=$1
  fi

  git-stash-or-trash
  stashed=$? # 0 if no changes or overwritten, 1 if stashed, 2 if not a git repo

  if [ $stashed -gt 1 ]; then
    echo "$RED""Stash or trash failed. Exiting."
    return 1
  fi

  gco $branch_name
  gfp
  [ $stashed -eq 1 ] && git-apply-or-skip || echo "$GRN""No stashed changes to apply$NONE"
}
alias gpls="git-pull-latest-safely"
alias gplsm="git-pull-latest-safely main"

echo "$GRN""Sourced$NONE .aliases-post-scripts"
